# Environment Variables

# Supabase Configuration
# Get these values from your Supabase project settings:
# 1. Go to https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# 2. Copy the Project URL and paste it below
# 3. Copy the anon/public key and paste it below

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Authentication
# Set a strong password for app access
AUTH_PASSWORD=your-secure-password-here
# Generate a random 32+ character string for JWT signing
AUTH_SECRET=your-random-32-char-secret-here
